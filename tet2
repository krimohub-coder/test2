-- PRESS ENTER
local function pressEnter()
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
    end)
    pcall(function()
        if targetBox and targetBox:IsA("TextBox") then
            targetBox:ReleaseFocus(true)
        end
    end)
    pcall(function()
        if PlayerGui then
            for _, obj in ipairs(PlayerGui:GetDescendants()) do
                if (obj:IsA("TextButton") or obj:IsA("ImageButton")) and obj.Visible then
                    local name = string.lower(obj.Name)
                    local text = obj:IsA("TextButton") and string.lower(obj.Text) or ""
                    if name:find("submit") or name:find("redeem") or name:find("claim") or
                       text:find("submit") or text:find("redeem") or text:find("claim") then
                        if obj:FindFirstChild("MouseButton1Click") then
                            for _, conn in ipairs(getconnections(obj.MouseButton1Click)) do
                                pcall(function() conn:Fire() end)
                            end
                        end
                        pcall(function()
                            obj:CaptureFocus()
                            obj:ReleaseFocus(true)
                        end)
                        break
                    end
                end
            end
        end
    end)
end

-- COLLECT & REDEEM
local function collectAndRedeem(code)
    if not code or code == "" then return end
    if not _enabled then return end
    if _processingLock then return end
    _processingLock = true
    
    local cleanCode = string.upper(string.gsub(code, "%s+", ""))
    
    table.insert(_collectedCodes, cleanCode)
    _wordCount = #_collectedCodes
    updateWordDisplay()
    
    setStatus(_wordCount.."/".._targetCount.." codes", Color3.fromRGB(80, 220, 100))
    flashCode(cleanCode)
    
    if _wordCount >= _targetCount then
        setStatus("Redeeming...", Color3.fromRGB(80, 255, 120))
        if targetBox and targetBox:IsA("TextBox") then
            local combined = table.concat(_collectedCodes, " ")
            pcall(function()
                targetBox.Text = combined
                targetBox.CursorPosition = #combined + 1
            end)
        end
        task.wait(0.01)
        pressEnter()
        _enabled = false
        onBtn.Text = "OFF"
        onBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        onBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        onStroke.Color = Color3.fromRGB(220, 60, 60)
        setStatus("Redeemed! Auto OFF", Color3.fromRGB(255, 200, 50))
        _collectedCodes = {}
        _wordCount = 0
        updateWordDisplay()
    end
    _processingLock = false
end

-- PASTE CODE
local function pasteCode(text)
    if not _enabled then return end
    local code = text:gsub("%s+", "")
    if code == "" then return end
    if not targetBox then
        setStatus("No box selected — click Pick Box", Color3.fromRGB(255, 80, 80))
        return
    end
    if not targetBox.Parent then
        setStatus("Box gone — pick again", Color3.fromRGB(255, 80, 80))
        targetBox = nil
        return
    end
    if targetBox.Text == "" or targetBox.Text == " " then
        targetBox.Text = code
    else
        targetBox.Text = targetBox.Text .. "\n" .. code
    end
    setStatus("Pasted: " .. code, Color3.fromRGB(80, 255, 120))
    flashCode(code)
    collectAndRedeem(code)
end

-- GLOBAL BROADCAST REMOTE HOOK
local KNOWN_HASH = "631ab0616c0445747139929dee141f4f24b2d7393b69ef081421b99587bfe780"
local globalRemote = nil
local _hookActive = false

local function isGlobalBroadcast(a1, a2, a3)
    if type(a1) ~= "string" then return false end
    if #a1 < 1 or #a1 > 500 then return false end
    if type(a2) ~= "number" then return false end
    if type(a3) ~= "string" then return false end
    if not a3:find("Sounds", 1, true) then return false end
    return true
end

local function hookRemote(remote)
    if globalRemote then return end
    globalRemote = remote
    _hookActive = true
    setStatus("Listening — pick a box!", Color3.fromRGB(80, 255, 120))
    remote.OnClientEvent:Connect(function(a1, a2, a3)
        if type(a1) ~= "string" or #a1 < 1 then return end
        pasteCode(a1)
    end)
end

task.spawn(function()
    local ok, net = pcall(function()
        return RS:WaitForChild("Packages", 10):WaitForChild("Net", 10)
    end)
    if not ok or not net then
        setStatus("Net folder missing — rejoin?", Color3.fromRGB(255, 80, 80))
        return
    end

    local function findByHash(parent)
        for _, child in ipairs(parent:GetChildren()) do
            if child:IsA("RemoteEvent") and child.Name:find(KNOWN_HASH, 1, true) then
                return child
            end
            local r = findByHash(child)
            if r then return r end
        end
    end
    local found = findByHash(net)
    if found then
        hookRemote(found)
        return
    end

    setStatus("Auto-detecting broadcast remote...", Color3.fromRGB(200, 200, 50))

    local function attachCandidate(remote)
        remote.OnClientEvent:Connect(function(a1, a2, a3)
            if globalRemote then return end
            if isGlobalBroadcast(a1, a2, a3) then
                hookRemote(remote)
            end
        end)
    end

    local function scan(parent)
        for _, child in ipairs(parent:GetChildren()) do
            if child:IsA("RemoteEvent") then attachCandidate(child) end
            pcall(scan, child)
        end
    end
    scan(net)
    net.DescendantAdded:Connect(function(obj)
        if obj:IsA("RemoteEvent") and not globalRemote then
            attachCandidate(obj)
        end
    end)
end)

