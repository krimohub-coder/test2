-- ============================================
-- AUTO BUY
-- ============================================
local function isProximityPrompt(obj)
    if not obj or not obj:IsA("ProximityPrompt") then return false end
    local parent = obj.Parent
    if not parent or parent.Name ~= "PromptAttachment" then return false end
    local parent2 = parent.Parent
    if not parent2 or parent2.Name ~= "Part" then return false end
    local parent3 = parent2.Parent
    return parent3 and parent3:IsA("Model") and true or false
end

local function getPromptPosition(prompt)
    if prompt and prompt.Parent then
        if prompt.Parent:IsA("Attachment") and prompt.Parent.Name == "PromptAttachment" then
            local part = prompt.Parent.Parent
            if part and part.Name == "Part" then
                return part.Position
            end
        elseif prompt.Parent:IsA("BasePart") then
            return prompt.Parent.Position
        elseif prompt.Parent:IsA("Model") and prompt.Parent.PrimaryPart then
            return prompt.Parent.PrimaryPart.Position
        end
    end
    return nil
end

local function isPromptOnScreen(prompt)
    local pos = getPromptPosition(prompt)
    if not pos then return false end
    local _, onScreen = Workspace.CurrentCamera:WorldToViewportPoint(pos)
    return onScreen
end

local function holdPrompt(prompt)
    pcall(function()
        prompt:InputHoldBegin(Enum.UserInputType.MouseButton1)
        prompt:InputHoldBegin(Enum.UserInputType.Touch)
    end)
end

local function releasePrompt(prompt)
    pcall(function()
        prompt:InputHoldEnd(Enum.UserInputType.MouseButton1)
        prompt:InputHoldEnd(Enum.UserInputType.Touch)
    end)
end

local function addPrompt(prompt)
    if isProximityPrompt(prompt) and not _proximityPrompts[prompt] then
        _proximityPrompts[prompt] = true
    end
end

local function startAutoBuy()
    if _autoBuyRunning then return end
    _autoBuyRunning = true
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        addPrompt(obj)
    end
    
    _promptConnection = Workspace.DescendantAdded:Connect(addPrompt)
    
    _renderConnection = RunService.RenderStepped:Connect(function()
        if not _autoBuyRunning then return end
        local character = LocalPlayer.Character
        if not character then return end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        for prompt, _ in pairs(_proximityPrompts) do
            if prompt and prompt.Parent and isProximityPrompt(prompt) then
                local pos = getPromptPosition(prompt)
                if pos then
                    local distance = (rootPart.Position - pos).Magnitude
                    local onScreen = isPromptOnScreen(prompt)
                    if distance < 15 and onScreen then
                        holdPrompt(prompt)
                    else
                        releasePrompt(prompt)
                    end
                else
                    _proximityPrompts[prompt] = nil
                end
            else
                _proximityPrompts[prompt] = nil
            end
        end
    end)
    
    setStatus("Auto Buy ON - Buying!", Color3.fromRGB(80, 255, 120))
end

local function stopAutoBuy()
    _autoBuyRunning = false
    if _renderConnection then
        _renderConnection:Disconnect()
